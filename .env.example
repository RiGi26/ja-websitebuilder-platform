# Website Builder Platform — Environment Variables
# Salin file ini ke .env.local lalu isi nilainya

# URL Japan Arena Corp Landing (untuk link "Kembali" di Navbar)
NEXT_PUBLIC_CORP_URL=https://japanarenacorp.com
NEXT_PUBLIC_SUPABASE_URL=https://chjgijlwhozeevrvhejt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNoamdpamx3aG96ZWV2cnZoZWp0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkxODEyNDYsImV4cCI6MjA5NDc1NzI0Nn0.S17mky9GiYGd3IW9xjIXKMKl5uNEMfwHrIcpJt8LOik

# Service role key — server-side only, JANGAN expose ke client bundle
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL untuk Midtrans callback redirect
NEXT_PUBLIC_BASE_URL=https://ja-websitebuilder-platform-nfoa.vercel.app

# Midtrans (PLATFORM — akun Japan Arena yang menagih customer pembuatan website)
#
# Mode sandbox/production DIPILIH RUNTIME dari DB (platform_settings.midtrans_mode,
# default 'production') dan di-switch dari /admin tanpa redeploy. Supaya toggle bekerja
# DUA ARAH, set KEDUA server key di bawah (keduanya hidup berdampingan; flag DB memilih
# mana dipakai). Server key = server-side ONLY, jangan expose ke client bundle.
# Ambil dari Midtrans Dashboard pada tab environment masing-masing (Sandbox / Production)
# → Settings → Access Keys. Catatan: prefix 'SB-' TIDAK selalu ada — bedakan dari tab
# environment dashboard, bukan dari bentuk key-nya.
# KOSONGKAN bila belum punya (placeholder non-kosong akan dikirim apa adanya ke Midtrans → 401).
MIDTRANS_SERVER_KEY_SANDBOX=
MIDTRANS_SERVER_KEY_PRODUCTION=
#
# Legacy (fallback): bila key per-mode di atas kosong, helper memakai MIDTRANS_SERVER_KEY
# untuk mode yang sama dengan NEXT_PUBLIC_MIDTRANS_ENV. Karena DB default = 'production',
# saat hanya mengandalkan legacy key WAJIB NEXT_PUBLIC_MIDTRANS_ENV=production — kalau tidak,
# mode production tak punya key yang bisa di-resolve → checkout 500.
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_ENV=production
#
# Catatan: platform checkout pakai REDIRECT Snap (redirect_url), bukan snap.js embed,
# jadi client key TIDAK dipakai di sisi platform. NEXT_PUBLIC_MIDTRANS_CLIENT_KEY hanya
# relevan kalau kelak ada embed snap.js di frontend.
# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx

# Fonnte WhatsApp Gateway — untuk notifikasi otomatis ke customer saat step berubah
# Dapatkan token di: https://md.fonnte.com/ (Device → Token)
# Server-side ONLY, jangan expose ke client bundle
FONNTE_TOKEN=your-fonnte-device-token

# ── Portal Operasi (Bakso Tini Fase 1 — integrasi order website→portal) ──
# Server-side ONLY. POST {PORTAL}/api/orders ditandatangani HMAC-SHA256 dgn PORTAL_API_SECRET
# (BAKSO_PORTAL_CONTRACT.md §8). Order GAGAL bila keduanya belum di-set (fail-closed).
#
# FASE 1: Portal masih STUB in-repo. Set PORTAL_API_URL ke origin deploy WB + "/api/_portal"
#   (mis. https://ja-websitebuilder-platform-nfoa.vercel.app/api/_portal). Stub mem-verifikasi
#   tanda tangan dgn PORTAL_API_SECRET yang SAMA (stub berperan sbg Portal).
# FASE 2 (Portal nyata live): cukup arahkan PORTAL_API_URL ke origin Portal — nol perubahan kode.
PORTAL_API_URL=
PORTAL_API_SECRET=