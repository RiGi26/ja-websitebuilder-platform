{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "../.tmp-gen-gadget",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": { "@/*": ["src/*"] },
