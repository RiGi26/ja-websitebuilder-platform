{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "../.tmp-gen-warung",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "node",
      "react"
    ],
    "strictNullChecks": true
  },
  "include": [
    "gen-warung-entry.tsx"
  ]
}
